# Copy to the repo root as `.env` on the server, then fill in real values.
# NEVER commit the filled-in .env file.

# Your public hostname (DuckDNS subdomain or your own domain).
# Must have an A record pointing at the VM's public IP before first boot,
# so Caddy can obtain the Let's Encrypt certificate.
DOMAIN=crave-chaos-kitchen.duckdns.org

# PostgreSQL
POSTGRES_USER=crave
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=food_delivery

# JWT signing key - generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
